---
import Layout from "../layouts/Layout.astro";
// Impor komponen React Anda. Sesuaikan path ini jika Anda menyimpannya di folder berbeda.
import TaskTable from "../components/Tables/TaskTable";
---

<Layout title="Task Manager & Reminder">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 fade-in">
        <!-- Header -->
        <div
            class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10"
        >
            <div>
                <h1
                    class="text-3xl font-extrabold text-slate-900 tracking-tight"
                >
                    Daftar Pekerjaan
                </h1>
                <p class="text-slate-500 mt-1.5 text-sm sm:text-base">
                    Pantau dan kelola task serta pengingat WhatsApp otomatis
                    Anda.
                </p>
            </div>
        </div>

        <!-- Render React Component -->
        <!-- Menggunakan client:only="react" untuk mencegah Astro melakukan SSR pada komponen ini di Cloudflare Worker -->
        <TaskTable client:only="react" />
    </div>
</Layout>
