---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Task Manager & Reminder">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 fade-in">
        <!-- Header & Action -->
        <div
            class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10"
        >
            <div>
                <h1
                    class="text-3xl font-extrabold text-slate-900 tracking-tight"
                >
                    Daftar Pekerjaan
                </h1>
                <p class="text-slate-500 mt-1.5 text-sm sm:text-base">
                    Pantau dan kelola task serta pengingat WhatsApp otomatis
                    Anda.
                </p>
            </div>
            <button
                onclick="openModal('add')"
                class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 flex items-center gap-2 shadow-lg shadow-indigo-200 hover:shadow-xl hover:-translate-y-0.5"
            >
                <i class="ph ph-plus text-xl"></i>
                Tambah Task
            </button>
        </div>

        <!-- Filters (Glassmorphism Card) -->
        <div
            class="bg-white/60 backdrop-blur-md p-5 rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-white mb-8 flex flex-col md:flex-row gap-5 items-end transition-all"
        >
            <div class="flex-1 w-full">
                <label
                    class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"
                    >Filter Tanggal</label
                >
                <div class="relative">
                    <i
                        class="ph ph-calendar text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2 text-lg"
                    ></i>
                    <input
                        type="date"
                        id="filterDate"
                        class="w-full bg-white/80 border-slate-200 text-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm pl-11 pr-4 py-2.5 transition-all outline-none"
                    />
                </div>
            </div>
            <div class="flex-1 w-full">
                <label
                    class="block text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-2"
                    >Filter Status</label
                >
                <div class="relative">
                    <i
                        class="ph ph-funnel text-slate-400 absolute left-3.5 top-1/2 -translate-y-1/2 text-lg"
                    ></i>
                    <select
                        id="filterStatus"
                        class="w-full bg-white/80 border-slate-200 text-slate-700 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm pl-11 pr-4 py-2.5 transition-all outline-none appearance-none"
                    >
                        <option value="All"
                            >Semua Aktif (Kecuali Selesai/Ditutup)</option
                        >
                        <option value="Pending">Pending</option>
                        <option value="Send 1st">Send 1st</option>
                        <option value="Send 2nd">Send 2nd</option>
                        <option value="Send">Send (Manual)</option>
                    </select>
                    <i
                        class="ph ph-caret-down text-slate-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"
                    ></i>
                </div>
            </div>
            <button
                onclick="fetchTasks()"
                class="bg-white hover:bg-slate-50 text-slate-700 px-6 py-2.5 rounded-xl font-semibold transition-all duration-200 flex items-center gap-2 border border-slate-200 shadow-sm w-full md:w-auto justify-center hover:border-slate-300"
            >
                Terapkan
            </button>
        </div>

        <!-- Table Container -->
        <div
            class="bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 overflow-hidden"
        >
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-100">
                    <thead class="bg-slate-50/50">
                        <tr>
                            <th
                                scope="col"
                                class="px-6 py-5 text-left text-xs font-bold text-slate-500 uppercase tracking-wider"
                                >Nama & Pekerjaan</th
                            >
                            <th
                                scope="col"
                                class="px-6 py-5 text-left text-xs font-bold text-slate-500 uppercase tracking-wider"
                                >Kontak WA</th
                            >
                            <th
                                scope="col"
                                class="px-6 py-5 text-left text-xs font-bold text-slate-500 uppercase tracking-wider"
                                >Tenggat Waktu</th
                            >
                            <th
                                scope="col"
                                class="px-6 py-5 text-left text-xs font-bold text-slate-500 uppercase tracking-wider"
                                >Status</th
                            >
                            <th
                                scope="col"
                                class="px-6 py-5 text-right text-xs font-bold text-slate-500 uppercase tracking-wider"
                                >Aksi</th
                            >
                        </tr>
                    </thead>
                    <tbody
                        id="taskTableBody"
                        class="bg-white divide-y divide-slate-100"
                    >
                        <!-- Data render by JS -->
                        <tr
                            ><td
                                colspan="5"
                                class="px-6 py-12 text-center text-slate-500"
                                ><div
                                    class="flex justify-center items-center gap-2"
                                >
                                    <i
                                        class="ph ph-spinner ph-spin text-2xl text-indigo-600"
                                    ></i> Memuat data...
                                </div></td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal Add/Edit -->
    <div
        id="taskModal"
        class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden z-50 overflow-y-auto transition-opacity duration-300 opacity-0"
        aria-labelledby="modal-title"
        role="dialog"
        aria-modal="true"
    >
        <div
            class="min-h-screen flex items-center justify-center p-4 text-center sm:p-0"
        >
            <div
                id="modalContent"
                class="relative bg-white rounded-3xl shadow-2xl max-w-lg w-full p-8 text-left transform transition-all duration-300 scale-95 opacity-0 border border-slate-100"
            >
                <div class="absolute top-6 right-6">
                    <button
                        onclick="closeModal()"
                        class="text-slate-400 hover:text-slate-600 bg-slate-50 hover:bg-slate-100 rounded-full p-2 transition-colors"
                    >
                        <i class="ph ph-x text-lg"></i>
                    </button>
                </div>

                <div class="mb-8">
                    <div
                        class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center mb-4 text-indigo-600"
                    >
                        <i class="ph-fill ph-note-pencil text-2xl"></i>
                    </div>
                    <h3
                        class="text-2xl font-extrabold text-slate-900 tracking-tight"
                        id="modalTitle"
                    >
                        Tambah Task
                    </h3>
                    <p class="text-sm text-slate-500 mt-1">
                        Lengkapi form di bawah untuk menyimpan pengingat baru.
                    </p>
                </div>

                <form id="taskForm" onsubmit="saveTask(event)">
                    <input type="hidden" id="taskId" />

                    <div class="space-y-5">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                            <div>
                                <label
                                    class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                    >Nama Klien/PIC</label
                                >
                                <input
                                    type="text"
                                    id="taskName"
                                    required
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all placeholder:text-slate-400"
                                    placeholder="Budi Santoso"
                                />
                            </div>
                            <div>
                                <label
                                    class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                    >No. WhatsApp</label
                                >
                                <input
                                    type="text"
                                    id="taskPhone"
                                    required
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all placeholder:text-slate-400"
                                    placeholder="08123456789"
                                />
                            </div>
                        </div>

                        <div>
                            <label
                                class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                >Judul Task</label
                            >
                            <input
                                type="text"
                                id="taskTitle"
                                required
                                class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all placeholder:text-slate-400"
                                placeholder="Meeting Presentasi Desain"
                            />
                        </div>

                        <div>
                            <label
                                class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                >Deskripsi Singkat</label
                            >
                            <textarea
                                id="taskDesc"
                                rows="3"
                                class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all placeholder:text-slate-400"
                                placeholder="Catatan tambahan untuk task ini..."
                            ></textarea>
                        </div>

                        <div>
                            <label
                                class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                >Tenggat Waktu (Deadline)</label
                            >
                            <input
                                type="datetime-local"
                                id="taskDeadline"
                                required
                                class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all"
                            />
                        </div>

                        <div id="statusGroup" class="hidden">
                            <label
                                class="block text-[13px] font-semibold text-slate-700 mb-1.5"
                                >Status Task (Manual)</label
                            >
                            <div class="relative">
                                <select
                                    id="taskStatus"
                                    class="w-full bg-slate-50 border border-slate-200 text-slate-900 rounded-xl focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 sm:text-sm px-4 py-3 outline-none transition-all appearance-none"
                                >
                                    <option value="Pending">Pending</option>
                                    <option value="Send 1st">Send 1st</option>
                                    <option value="Send 2nd">Send 2nd</option>
                                    <option value="Send">Send (Manual)</option>
                                    <option value="Finished">Finished</option>
                                    <option value="Closed">Closed</option>
                                </select>
                                <i
                                    class="ph ph-caret-down text-slate-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"
                                ></i>
                            </div>
                        </div>
                    </div>

                    <div
                        class="mt-8 flex justify-end gap-3 pt-6 border-t border-slate-100"
                    >
                        <button
                            type="button"
                            onclick="closeModal()"
                            class="px-5 py-2.5 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 rounded-xl font-semibold transition-all"
                            >Batal</button
                        >
                        <button
                            type="submit"
                            class="px-6 py-2.5 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white rounded-xl font-semibold transition-all shadow-md shadow-indigo-200 hover:shadow-lg"
                            >Simpan Data</button
                        >
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script is:inline>
        // State
        let currentTasks = [];

        // Global functions for React to call
        window.openModal = function(mode, id = null) {
            const modal = document.getElementById("taskModal");
            const content = document.getElementById("modalContent");
            const form = document.getElementById("taskForm");
            const statusGroup = document.getElementById("statusGroup");

            modal.classList.remove("hidden");
            setTimeout(() => {
                modal.classList.remove("opacity-0");
                content.classList.remove("scale-95", "opacity-0");
            }, 10);

            form.reset();

            if (mode === "add") {
                document.getElementById("modalTitle").innerText = "Tambah Task Baru";
                document.getElementById("taskId").value = "";
                statusGroup.classList.add("hidden");
            } else {
                document.getElementById("modalTitle").innerText = "Edit Data Task";
                statusGroup.classList.remove("hidden");
                
                // We need to fetch the task data if editing
                fetch(`/api/tasks/${id}`)
                    .then(res => res.json())
                    .then(task => {
                        document.getElementById("taskId").value = task.id;
                        document.getElementById("taskName").value = task.name;
                        document.getElementById("taskPhone").value = task.phone_number;
                        document.getElementById("taskTitle").value = task.title;
                        document.getElementById("taskDesc").value = task.description;
                        document.getElementById("taskStatus").value = task.status;
                        
                        const dt = new Date(task.deadline);
                        dt.setMinutes(dt.getMinutes() - dt.getTimezoneOffset());
                        document.getElementById("taskDeadline").value = dt.toISOString().slice(0, 16);
                    });
            }
        }

        window.closeModal = function() {
            const modal = document.getElementById("taskModal");
            const content = document.getElementById("modalContent");

            modal.classList.add("opacity-0");
            content.classList.add("scale-95", "opacity-0");

            setTimeout(() => {
                modal.classList.add("hidden");
            }, 300);
        }

        // CRUD Actions
        async function saveTask(e) {
            e.preventDefault();
            const id = document.getElementById("taskId").value;
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerText;

            btn.innerHTML = '<i class="ph ph-spinner ph-spin text-lg"></i> Menyimpan...';
            btn.disabled = true;

            const payload = {
                name: document.getElementById("taskName").value,
                phone_number: document.getElementById("taskPhone").value,
                title: document.getElementById("taskTitle").value,
                description: document.getElementById("taskDesc").value,
                deadline: document.getElementById("taskDeadline").value,
            };

            let url = "/api/tasks";
            let method = "POST";

            if (id) {
                url = `/api/tasks/${id}`;
                method = "PUT";
                payload.status = document.getElementById("taskStatus").value;
            }

            try {
                await fetch(url, {
                    method,
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });

                // Trigger React refresh
                window.dispatchEvent(new CustomEvent('refreshTasks'));
                closeModal();
            } catch (err) {
                alert("Gagal menyimpan data.");
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }
    </script>
</Layout>
e: document.getElementById("taskName").value,
                phone_number: document.getElementById("taskPhone").value,
                title: document.getElementById("taskTitle").value,
                description: document.getElementById("taskDesc").value,
                deadline: document.getElementById("taskDeadline").value,
            };

            let url = "/api/tasks";
            let method = "POST";

            if (id) {
                url = `/api/tasks/${id}`;
                method = "PUT";
                payload.status = document.getElementById("taskStatus").value;
            }

            await fetch(url, {
                method,
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
            });

            btn.innerHTML = originalText;
            btn.disabled = false;
            closeModal();
            fetchTasks();
        }

        async function deleteTask(id) {
            if (
                confirm(
                    "Apakah Anda yakin ingin menghapus task ini? Data tidak dapat dikembalikan.",
                )
            ) {
                await fetch(`/api/tasks/${id}`, { method: "DELETE" });
                fetchTasks();
            }
        }

        async function manualRemind(id) {
            if (
                confirm(
                    'Kirim reminder manual sekarang? (Pesan WA akan dikirim dan status berubah menjadi "Send")',
                )
            ) {
                await fetch(`/api/tasks/${id}/remind`, { method: "POST" });
                fetchTasks();
            }
        }

        // Init
        document.addEventListener("DOMContentLoaded", fetchTasks);
    </script>
</Layout>
