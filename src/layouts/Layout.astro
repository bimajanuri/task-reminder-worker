---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Astro description" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <!-- Phosphor Icons untuk icon yang bersih -->
        <script src="https://unpkg.com/@phosphor-icons/web"></script>

        <style>
            @import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap");

            /* Custom Scrollbar yang elegan */
            ::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }
            ::-webkit-scrollbar-track {
                background: transparent;
            }
            ::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }
            ::-webkit-scrollbar-thumb:hover {
                background: #94a3b8;
            }
        </style>
    </head>
    <body
        class="text-slate-800 antialiased min-h-screen flex flex-col bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-indigo-50 via-slate-50 to-white"
    >
        <!-- Navigasi dengan efek Glassmorphism -->
        <nav
            class="bg-white/70 backdrop-blur-lg border-b border-white/50 sticky top-0 z-10 shadow-[0_4px_30px_rgba(0,0,0,0.03)]"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16 items-center">
                    <div class="flex items-center gap-3">
                        <div
                            class="bg-gradient-to-br from-indigo-500 to-purple-600 p-2 rounded-xl shadow-lg shadow-indigo-200"
                        >
                            <i
                                class="ph-fill ph-bell-ringing text-white text-xl"
                            ></i>
                        </div>
                        <span
                            class="font-extrabold text-xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-slate-900 to-slate-700"
                            >TaskReminder<span class="text-indigo-600">.</span
                            ></span
                        >
                    </div>
                    <div
                        class="hidden sm:flex items-center gap-4 text-sm font-medium text-slate-500"
                    >
                        <span class="flex items-center gap-1"
                            ><i class="ph ph-clock text-lg"></i> Real-time Worker</span
                        >
                    </div>
                </div>
            </div>
        </nav>

        <main class="flex-grow">
            <slot />
        </main>
    </body>
</html>
