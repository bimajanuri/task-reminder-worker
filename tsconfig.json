{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext"
    ],
    "types": [
      "@cloudflare/workers-types"
    ], // Tambahkan ini (PENTING)
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  }
}